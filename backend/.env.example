# Copy this file to .env and fill in your real values.
# .env is gitignored — it never leaves your machine.
# These secrets live in Supabase environment variables in production.
# Set them with:  supabase secrets set KEY=VALUE ...

ECOWITT_APP_KEY=YOUR_ECOWITT_APP_KEY
ECOWITT_API_KEY=YOUR_ECOWITT_API_KEY
ECOWITT_MAC_BACKYARD=YOUR_BACKYARD_GATEWAY_MAC
ECOWITT_MAC_SIDEYARDS=YOUR_SIDEYARDS_GATEWAY_MAC
WEATHER_LAT=34.0714
WEATHER_LON=-118.228

# Set to "true" to log every fetch into public.plantwatch_soil_readings
LOG_HISTORY=true
